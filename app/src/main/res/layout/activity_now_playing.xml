<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/now_playing_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="16dp">

    <ImageView
        android:id="@+id/img_track_icon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginBottom="16dp"
        android:src="@drawable/ic_audio"
        android:contentDescription="Track Icon" />

    <TextView
        android:id="@+id/text_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Song Title"
        android:textColor="@color/text_primary"
        android:textSize="28sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        android:gravity="center"
        android:letterSpacing="0.01" />

    <TextView
        android:id="@+id/text_artist"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Artist Name"
        android:textColor="#CCFFFFFF"
        android:textSize="18sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:gravity="center" />

    <TextView
        android:id="@+id/text_album"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:text="Album Name"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:textStyle="italic"
        android:maxLines="1"
        android:ellipsize="end"
        android:gravity="center" />

    <TextView
        android:id="@+id/text_playlist_pos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:text="0 / 0"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:gravity="center" />

    <TextView
        android:id="@+id/text_bitrate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="--- kbps | -- kHz"
        android:textColor="@color/text_primary"
        android:textSize="12sp"
        android:gravity="center"
        android:fontFamily="monospace" />

    <com.example.bitperfectplayer.AnimatedWaveformView
        android:id="@+id/animated_waveform"
        android:layout_width="600dp"
        android:layout_height="56dp"
        android:layout_marginTop="14dp" />

    <SeekBar
        android:id="@+id/seek_bar"
        android:layout_width="600dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:progressTint="@color/text_primary"
        android:thumbTint="@color/text_primary" />

    <LinearLayout
        android:layout_width="600dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/text_current_time"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0:00"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/text_total_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:padding="4dp">

        <ImageButton
            android:id="@+id/btn_shuffle"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/control_button_bg"
            android:src="@drawable/ic_shuffle"
            android:contentDescription="Shuffle"
            android:focusable="true"
            android:padding="14dp"
            android:scaleType="fitCenter"
            android:tint="@color/text_primary"
            android:alpha="0.5" />

        <ImageButton
            android:id="@+id/btn_prev"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/control_button_bg"
            android:src="@drawable/ic_skip_prev"
            android:contentDescription="Previous"
            android:focusable="true"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:tint="@color/text_primary" />

        <ImageButton
            android:id="@+id/btn_play_pause"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginHorizontal="16dp"
            android:background="@drawable/control_button_bg"
            android:src="@drawable/ic_play"
            android:contentDescription="Play/Pause"
            android:focusable="true"
            android:padding="14dp"
            android:scaleType="fitCenter"
            android:tint="@color/text_primary" />

        <ImageButton
            android:id="@+id/btn_next"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/control_button_bg"
            android:src="@drawable/ic_skip_next"
            android:contentDescription="Next"
            android:focusable="true"
            android:padding="12dp"
            android:scaleType="fitCenter"
            android:tint="@color/text_primary" />

        <ImageButton
            android:id="@+id/btn_repeat"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/control_button_bg"
            android:src="@drawable/ic_repeat"
            android:contentDescription="Repeat"
            android:focusable="true"
            android:padding="14dp"
            android:scaleType="fitCenter"
            android:tint="@color/text_primary"
            android:alpha="0.5" />

        <ImageButton
            android:id="@+id/btn_playlist"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/control_button_bg"
            android:src="@drawable/ic_queue_music"
            android:contentDescription="Playlist"
            android:focusable="true"
            android:padding="14dp"
            android:scaleType="fitCenter"
            android:tint="@color/text_primary" />

        <!-- USB DAC reset button — glows at full opacity when a DAC is connected,
             dims to 30% when none is detected. Tap = reset sink, Long-press = device info.
             Tint is applied at runtime to match the selected color scheme. -->
        <ImageButton
            android:id="@+id/btn_dac_reset"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginStart="16dp"
            android:background="@drawable/control_button_bg"
            android:src="@drawable/ic_dac"
            android:contentDescription="Reset USB DAC"
            android:focusable="true"
            android:padding="14dp"
            android:scaleType="fitCenter"
            android:alpha="0.3" />

    </LinearLayout>

</LinearLayout>
