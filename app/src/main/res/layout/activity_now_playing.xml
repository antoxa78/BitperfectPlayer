<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/now_playing_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="16dp">

    <ImageView
        android:id="@+id/img_track_icon"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginBottom="12dp"
        android:src="@drawable/ic_audio"
        android:contentDescription="Track Icon" />

    <TextView
        android:id="@+id/text_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Song Title"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        android:gravity="center" />

    <TextView
        android:id="@+id/text_artist"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Artist Name"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:gravity="center" />

    <TextView
        android:id="@+id/text_album"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="Album Name"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:gravity="center" />

    <TextView
        android:id="@+id/text_playlist_pos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="0 / 0"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:gravity="center" />

    <TextView
        android:id="@+id/text_bitrate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="--- kbps | -- kHz"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:gravity="center" />


    <com.example.bitperfectplayer.AnimatedWaveformView
        android:id="@+id/animated_waveform"
        android:layout_width="600dp"
        android:layout_height="64dp"
        android:layout_marginTop="12dp" />

    <SeekBar
        android:id="@+id/seek_bar"
        android:layout_width="600dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:progressTint="#FFFFFF"
        android:thumbTint="#FFFFFF" />

    <LinearLayout
        android:layout_width="600dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/text_current_time"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0:00"
            android:textColor="#AAAAAA"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/text_total_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textColor="#AAAAAA"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:padding="4dp">

        <ImageButton
            android:id="@+id/btn_shuffle"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/control_button_bg"
            android:src="@drawable/ic_shuffle"
            android:contentDescription="Shuffle"
            android:focusable="true"
            android:padding="16dp"
            android:scaleType="fitCenter"
            android:tint="#FFFFFF"
            android:alpha="0.5" />

        <ImageButton
            android:id="@+id/btn_prev"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/control_button_bg"
            android:src="@drawable/ic_skip_prev"
            android:contentDescription="Previous"
            android:focusable="true"
            android:padding="16dp"
            android:scaleType="fitCenter"
            android:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/btn_play_pause"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginHorizontal="12dp"
            android:background="@drawable/control_button_bg"
            android:src="@drawable/ic_play"
            android:contentDescription="Play/Pause"
            android:focusable="true"
            android:padding="14dp"
            android:scaleType="fitCenter"
            android:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/btn_next"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/control_button_bg"
            android:src="@drawable/ic_skip_next"
            android:contentDescription="Next"
            android:focusable="true"
            android:padding="16dp"
            android:scaleType="fitCenter"
            android:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/btn_repeat"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/control_button_bg"
            android:src="@drawable/ic_repeat"
            android:contentDescription="Repeat"
            android:focusable="true"
            android:padding="16dp"
            android:scaleType="fitCenter"
            android:tint="#FFFFFF"
            android:alpha="0.5" />

        <ImageButton
            android:id="@+id/btn_playlist"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/control_button_bg"
            android:src="@drawable/ic_queue_music"
            android:contentDescription="Playlist"
            android:focusable="true"
            android:padding="16dp"
            android:scaleType="fitCenter"
            android:tint="#FFFFFF" />

    </LinearLayout>

</LinearLayout>
